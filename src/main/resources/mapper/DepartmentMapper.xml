<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.eflow.mapper.DepartmentMapper">

    <resultMap id="DepartmentResultMap" type="com.eflow.entity.Department">
        <id     property="id"        column="id"/>
        <result property="name"      column="name"/>
        <result property="sortOrder" column="sort_order"/>
    </resultMap>

    <sql id="BaseColumns">id, name, sort_order</sql>

    <!-- ── READ ─────────────────────────────────────────────────────── -->

    <select id="findAll" resultMap="DepartmentResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM departments
        ORDER BY sort_order, name
    </select>

    <select id="findById" resultMap="DepartmentResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM departments
        WHERE id = #{id}
    </select>

    <select id="existsByNameIgnoreCase" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM departments
        WHERE LOWER(name) = LOWER(#{name})
    </select>

    <select id="existsByNameIgnoreCaseAndIdNot" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM departments
        WHERE LOWER(name) = LOWER(#{name})
          AND id != #{id}
    </select>

    <select id="maxSortOrder" resultType="int">
        SELECT COALESCE(MAX(sort_order), -1) FROM departments
    </select>

    <!-- ── WRITE ─────────────────────────────────────────────────────── -->

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO departments (name, sort_order)
        VALUES (#{name}, #{sortOrder})
    </insert>

    <update id="update">
        UPDATE departments
        SET name       = #{name},
            sort_order = #{sortOrder}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM departments WHERE id = #{id}
    </delete>

</mapper>
