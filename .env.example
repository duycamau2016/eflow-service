# ═══════════════════════════════════════════════════════════════
#  eFlow Service - Railway Environment Variables Template
#  Copy các biến này vào Railway → Service → Variables tab
# ═══════════════════════════════════════════════════════════════

# ─── BẮTBUỘC: Tự inject bởi Railway PostgreSQL Plugin ────────
# Vào Railway → Project → Add Plugin → PostgreSQL
# Sau khi thêm plugin, các biến này sẽ tự xuất hiện:
PGHOST=your-railway-postgres-host.railway.internal
PGPORT=5432
PGDATABASE=railway
PGUSER=postgres
PGPASSWORD=your-password-here

# ─── BẮTBUỘC: Spring Boot profile ───────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ─── Tự động bởi Railway (KHÔNG cần set thủ công) ────────────
# PORT=8080   ← Railway inject tự động

# ─── TÙY CHỌN: Giới hạn CORS (mặc định cho phép tất cả) ─────
# Nếu muốn chỉ cho phép domain cụ thể, uncomment và sửa:
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-domain.com
